# ─────────────────────────────────────────────────────────
#  LOCAL DEVELOPMENT  →  uses Docker containers
#  PRODUCTION         →  uses Railway (backend) + Vercel (frontend)
# ─────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────
# LOCAL  (docker-compose service name)
DATABASE_URL=postgresql://chatbot_user:chatbot_pass@postgres:5432/chatbot_db
# PRODUCTION  (Railway gives you this automatically)
# DATABASE_URL=${{Postgres.DATABASE_URL}}

# ── Redis ─────────────────────────────────────────────────
# LOCAL
REDIS_URL=redis://redis:6379
# PRODUCTION  (Railway gives you this automatically)
# REDIS_URL=${{Redis.REDIS_URL}}

# ── JWT ───────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_this_to_a_64_char_random_string_before_running

# ── GROQ AI (free) ──────────────────────────────────────
# Get from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ── Nodemailer + Brevo SMTP (free 300 emails/day) ─────────
# Get from: https://app.brevo.com → SMTP & API → SMTP tab
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=your_brevo_login_email@gmail.com
BREVO_SMTP_PASS=your_brevo_smtp_key_here

# ── App ───────────────────────────────────────────────────
PORT=4000
# LOCAL
FRONTEND_URL=http://localhost:5173
# PRODUCTION (your Vercel URL)
# FRONTEND_URL=https://your-app.vercel.app

FROM_EMAIL=support@yourdomain.com
FROM_NAME=Support Team
NODE_ENV=development
