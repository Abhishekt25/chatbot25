# ─────────────────────────────────────────────────────────
#  LOCAL: leave VITE_BACKEND_URL empty → Vite proxy handles it
#  VERCEL: set VITE_BACKEND_URL to your Railway backend URL
# ─────────────────────────────────────────────────────────

# LOCAL (leave blank — Vite proxy handles /api and /socket.io)
VITE_BACKEND_URL=

# PRODUCTION on Vercel (uncomment and set your Railway URL)
# VITE_BACKEND_URL=https://your-chatbot-backend.up.railway.app
